<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Navbar Design</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      background:#f5f5f5;
    }

    /* Top Navbar */
    .navbar{
      width:100%;
      background:#ffffff;
      border-bottom:1px solid #ddd;
      padding:15px 40px;
      display:flex;
      align-items:center;
      justify-content:space-between;
    }

    /* Left Menu */
    .menu{
      display:flex;
      gap:30px;
      align-items:center;
    }

    .menu a{
      text-decoration:none;
      color:#111;
      font-size:15px;
      font-weight:600;
      transition:0.3s;
    }

    .menu a:hover{
      color:#c79a3b;
    }

    .sale{
      color:red;
    }

    /* Search Bar */
    .search-box{
      position:relative;
    }

    .search-box input{
      width:250px;
      padding:10px 40px 10px 15px;
      border:1px solid
      border-radius:25px;
      outline:none;
      font-size:14px;
    }

    .search-box button{
      position:absolute;
      right:5px;
      top:50%;
      transform:translateY(-50%);
      border:none;
      background:#111;
      color:white;
      width:32px;
      height:32px;
      border-radius:50%;
      cursor:pointer;
    }

    .search-box button:hover{
      background:#c79a3b;
    }
  </style>
</head>
<body>
  <header>
    <div class="logo">
      <h1>luxury watches</h1>
    </div>

  <nav class="navbar">

    <!-- Menu -->
    <div class="menu">
      <a href="#" class="sale">SALE</a>
      <a href="#">BRANDS</a>
      <a href="#">MAN</a>
      <a href="#">WOMAN</a>
      <a href="#">LUXURY</a>
      <a href="#">GIFTING</a>
    </div>

    <!-- Search -->
    <div class="search-box">
      <input type="text" placeholder="Search products...">
      <button>🔍</button>
    </div>

  </nav>

</body>
</html>

