<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Watch Navbar</title>

  <!-- Remix Icon -->
  <link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:, sans-serif;
    }

    body{
      background:#f5f5f5;
    }

    /* TOP BAR */
    .top-bar{
      width:100%;
      background:rgb(134, 186, 229);a
      border-bottom:1px solid #e5e5e5;
      padding:18px 60px;
      display:flex;
      align-items:center;
      justify-content:space-between;
    }

    .top-left{
      display:flex;
      gap:35px;
      align-items:center;
    }

    .top-left a{
      text-decoration:none;
      color:#111;
      font-size:15px;
      display:flex;
      align-items:center;
      gap:8px;
    }

    .logo{
      font-size:38px;
      font-weight:bold;
      letter-spacing:3px;
      color:#111;
      text-transform:uppercase;
    }

    .top-icons{
      display:flex;
      gap:25px;
      align-items:center;
    }

    .top-icons i{
      font-size:22px;
      cursor:pointer;
      transition:0.3s;
    }

    .top-icons i:hover{
      color:#c79a3b;
    }

    /* SECOND NAVBAR */
    .navbar{
      width:100%;
      background:rgb(248, 250, 252);
      padding:18px 60px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      border-bottom:1px solid #e5e5e5;
    }

    .menu{
      display:flex;
      gap:35px;
      align-items:center;
    }

    .menu a{
      text-decoration:none;
      color:#111;
      font-size:17px;
      transition:0.3s;
    }

    .menu a:hover{
      color:#c79a3b;
    }

    .search-box{
      position:relative;
    }

    .search-box input{
      width:250px;
      padding:14px 45px 14px 18px;
      border:1px solid #ddd;
      outline:none;
      font-size:15px;
    }

    .search-box i{
      position:absolute;
      right:15px;
      top:50%;
      transform:translateY(-50%);
      color:#111;
      font-size:18px;
      cursor:pointer;
    }

    .search-box i:hover{
      color:#c79a3b;
    }

    /* SLIDER IMAGE */
    .slider{
      width:100%;
      height:500px;
      overflow:hidden;
    }

    .slider img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    /* MODAL */
    .modal {
      display:none;
      position:fixed;
      z-index:1000;
      left:0;
      top:0;
      width:100%;
      height:100%;
      background:rgba(0,0,0,0.5);
    }

    .modal-content {
      background:#fff;
      margin:8% auto;
      padding:20px;
      width:400px;
      border-radius:8px;
    }

    .close {
      float:right;
      font-size:22px;
      cursor:pointer;
    }

    .tabs {
      display:flex;
      justify-content:center;
      margin-bottom:20px;
    }

    .tabs button {
      flex:1;
      padding:12px;
      border:none;
      background:#eee;
      cursor:pointer;
      font-size:16px;
      transition:0.3s;
    }

    .tabs button.active {
      background:rgb(134, 186, 229);
      color:#fff;
    }

    .tab-content {
      display:none;
    }

    .tab-content.active {
      display:block;
      text-align:center;
    }

    .tab-content input {
      width:90%;
      padding:10px;
      margin:10px 0;
      border:1px solid #ddd;
    }

    .tab-content button {
      width:95%;
      padding:12px;
      background:rgb(134, 186, 229);
      border:none;
      color:#fff;
      font-size:16px;
      cursor:pointer;
      transition:0.3s;
    }

    .tab-content button:hover {
      background:#c79a3b;
    }
  </style>
</head>

<body>

  <!-- FIRST LINE -->
  <div class="top-bar">
    <div class="top-left">
      <a href="#"><i class="ri-map-pin-line"></i> Stores</a>
      <a href="#"><i class="ri-phone-line"></i> Contact Us</a>
    </div>

    <div class="logo">Luxury Watches</div>

    <div class="top-icons">
      <i class="ri-user-line" id="userBtn" title="Login / Sign Up"></i>
      <i class="ri-heart-line"></i>
      <i class="ri-shopping-bag-line"></i>
    </div>
  </div>

  <!-- SECOND NAVBAR -->
  <div class="navbar">
    <div class="menu">
      <a href="#">All Watches</a>
      <a href="#">Men</a>
      <a href="#">Women</a>
      <a href="#">Smart</a>
      <a href="#">Brands</a>
      <a href="#">Offers</a>
    </div>

    <div class="search-box">
      <input type="text" placeholder="Search entire store here...">
      <i class="ri-search-line"></i>
    </div>
  </div>

  <!-- IMAGE BELOW NAVBAR -->
  <div class="slider">
    <img src="https://i.pinimg.com/736x/1b/20/75/1b20752a3e8b29d1e20190d598f956c4.jpg" alt="slider image">
  </div>

  <!-- USER MODAL -->
  <div id="userModal" class="modal">
    <div class="modal-content">
      <span class="close" id="closeUser">&times;</span>
      <div class="tabs">
        <button id="loginTab" class="active">Login</button>
        <button id="signupTab">Sign Up</button>
      </div>

      <!-- LOGIN FORM -->
      <div id="loginContent" class="tab-content active">
        <h2>Login</h2>
        <form>
          <input type="email" placeholder="Email" required>
          <input type="password" placeholder="Password" required>
          <button type="submit">Login</button>
        </form>
      </div>

      <!-- SIGNUP FORM -->
      <div id="signupContent" class="tab-content">
        <h2>Create Account</h2>
        <form>
          <input type="text" placeholder="Full Name" required>
          <input type="email" placeholder="Email" required>
          <input type="password" placeholder="Password" required>
          <button type="submit">Sign Up</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    const userBtn = document.getElementById("userBtn");
    const userModal = document.getElementById("userModal");
    const closeUser = document.getElementById("closeUser");

    const loginTab = document.getElementById("loginTab");
    const signupTab = document.getElementById("signupTab");
    const loginContent = document.getElementById("loginContent");
    const signupContent = document.getElementById("signupContent");

    userBtn.onclick = () => userModal.style.display = "block";
    closeUser.onclick = () => userModal.style.display = "none";

    window.onclick = (event) => {
      if (event.target == userModal) userModal.style.display = "none";
    }

    loginTab.onclick = () => {
      loginTab.classList.add("active");
      signupTab.classList.remove("active");
      loginContent.classList.add("active");
      signupContent.classList.remove("active");
    }

    signupTab.onclick = () => {
      signupTab.classList.add("active");
      loginTab.classList.remove("active");
      signupContent.classList.add("active");
      loginContent.classList.remove("active");
    }
  </script>

</body>
</html>
